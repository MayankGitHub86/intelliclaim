# =============================================================================
# IntelliClaim Vision API - Environment Configuration
# =============================================================================
# 
# SECURITY NOTE: This is a template file. Copy to .env and update with actual values.
# NEVER commit .env files to version control - they contain sensitive credentials.
# 
# Quick Setup:
#   cp .env.example .env
#   # Edit .env with your actual values
# 
# =============================================================================

# =============================================================================
# Application Configuration
# =============================================================================

# Application identity and basic settings
APP_NAME=IntelliClaim Vision API
APP_VERSION=1.0.0
APP_DESCRIPTION=AI-powered insurance claims processing platform

# Environment: development, staging, production
ENVIRONMENT=development

# Debug mode - NEVER enable in production
DEBUG=true

# Logging configuration
LOG_LEVEL=DEBUG  # DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_FORMAT=json  # json, text
LOG_FILE_PATH=./logs/app.log
LOG_MAX_SIZE=10485760  # 10MB
LOG_BACKUP_COUNT=5

# API Configuration
API_V1_PREFIX=/api/v1
DOCS_URL=/docs
REDOC_URL=/redoc
OPENAPI_URL=/openapi.json

# Server settings
HOST=0.0.0.0
PORT=8000
WORKERS=1  # Number of uvicorn workers (increase for production)

# =============================================================================
# Security Configuration
# =============================================================================

# JWT Settings - CRITICAL: Change in production!
SECRET_KEY=B2br40_2XXrW1hl5AdDoY1njhgngsITKd1dClT8vgLA
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Password hashing
BCRYPT_ROUNDS=12

# CORS Settings
CORS_ORIGINS=["http://localhost:3000", "http://localhost:8080", "https://your-frontend-domain.com"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["GET", "POST", "PUT", "DELETE", "OPTIONS"]
CORS_ALLOW_HEADERS=["*"]

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60  # seconds

# =============================================================================
# Database Configuration
# =============================================================================

# Primary PostgreSQL Database
DATABASE_URL=postgresql+asyncpg://intelliclaim_user:intelliclaim_password@localhost:5432/intelliclaim
DB_HOST=localhost
DB_PORT=5432
DB_NAME=intelliclaim
DB_USER=intelliclaim_user
DB_PASSWORD=intelliclaim_password

# Database connection pool settings
DB_POOL_SIZE=10
DB_POOL_OVERFLOW=20
DB_POOL_TIMEOUT=30

# Test Database (for running tests)
TEST_DATABASE_URL=postgresql+asyncpg://intelliclaim_user:intelliclaim_password@localhost:5432/intelliclaim_test
TEST_DB_NAME=intelliclaim_test

# Database migration settings
ALEMBIC_CONFIG=alembic.ini
AUTO_MIGRATE=false  # Set to true for automatic migrations on startup

# =============================================================================
# Redis Configuration
# =============================================================================

# Primary Redis for caching
REDIS_URL=redis://:intelliclaim_redis_password@localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=intelliclaim_redis_password
REDIS_DB=0

# Cache settings
CACHE_TTL=3600  # Default cache TTL in seconds
CACHE_PREFIX=intelliclaim:

# Session storage
SESSION_REDIS_DB=2
SESSION_TTL=86400  # 24 hours

# =============================================================================
# Celery Configuration (Background Tasks)
# =============================================================================

# Celery broker and result backend
CELERY_BROKER_URL=redis://:intelliclaim_redis_password@localhost:6379/1
CELERY_RESULT_BACKEND=redis://:intelliclaim_redis_password@localhost:6379/1

# Celery settings
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=["json"]
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true

# Task routing
CELERY_TASK_ROUTES={}
CELERY_TASK_TIME_LIMIT=300  # 5 minutes
CELERY_TASK_SOFT_TIME_LIMIT=240  # 4 minutes

# Worker settings
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_TASKS_PER_CHILD=1000

# =============================================================================
# AI Service Configuration
# =============================================================================

# OpenAI Configuration
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4o-mini  # Free tier friendly model
OPENAI_MAX_TOKENS=4000
OPENAI_TEMPERATURE=0.1
OPENAI_TIMEOUT=30

# OpenAI Usage Limits (to control costs)
OPENAI_MAX_REQUESTS_PER_MINUTE=50
OPENAI_MAX_TOKENS_PER_MINUTE=40000

# Pinecone Vector Database (Free tier: 1 environment, 1 index)
PINECONE_API_KEY=your-pinecone-api-key-here
PINECONE_ENVIRONMENT=your-pinecone-environment  # e.g., us-east1-gcp
PINECONE_INDEX_NAME=intelliclaim-embeddings
PINECONE_DIMENSION=1536  # OpenAI text-embedding-ada-002 dimension
PINECONE_METRIC=cosine

# HuggingFace Configuration (Free tier)
HUGGINGFACE_API_KEY=hf_your-huggingface-token-here
HUGGINGFACE_MODEL_CACHE_DIR=./storage/models/huggingface
HF_INFERENCE_ENDPOINT=https://api-inference.huggingface.co

# Local AI Models (when using local inference)
LOCAL_MODELS_ENABLED=false
LOCAL_MODELS_DIR=./storage/models/local

# =============================================================================
# File Storage Configuration
# =============================================================================

# Storage directories
UPLOAD_DIR=./storage/uploads
MODELS_DIR=./storage/models
TEMP_DIR=./storage/temp
EXPORTS_DIR=./storage/exports
CACHE_DIR=./storage/cache

# File upload limits
MAX_FILE_SIZE=52428800  # 50MB in bytes
MAX_FILES_PER_REQUEST=10
ALLOWED_UPLOAD_EXTENSIONS=[".pdf", ".jpg", ".jpeg", ".png", ".tiff", ".bmp", ".doc", ".docx", ".xls", ".xlsx"]

# Image processing settings
MAX_IMAGE_WIDTH=4096
MAX_IMAGE_HEIGHT=4096
IMAGE_QUALITY=85
THUMBNAIL_SIZE=300

# Document processing
PDF_MAX_PAGES=50
DOC_PROCESSING_TIMEOUT=120  # seconds
OCR_ENABLED=true
OCR_LANGUAGE=eng

# File retention
TEMP_FILE_RETENTION_HOURS=24
UPLOAD_FILE_RETENTION_DAYS=30
PROCESSED_FILE_RETENTION_DAYS=90

# =============================================================================
# Computer Vision Configuration
# =============================================================================

# Model paths and settings
CV_MODELS_DIR=./storage/models/cv
YOLO_MODEL_PATH=./storage/models/cv/yolov8n.pt  # Nano model for speed
YOLO_CONFIDENCE_THRESHOLD=0.5
YOLO_IOU_THRESHOLD=0.45

# Object detection settings
DETECT_VEHICLES=true
DETECT_DAMAGE=true
DETECT_PEOPLE=false  # Privacy consideration
DETECT_DOCUMENTS=true

# Image preprocessing
AUTO_ENHANCE_IMAGES=true
NORMALIZE_BRIGHTNESS=true
SHARPEN_IMAGES=false

# Processing limits
MAX_BATCH_SIZE=10
CV_PROCESSING_TIMEOUT=60  # seconds per image
PARALLEL_PROCESSING=true
MAX_PARALLEL_JOBS=4

# Model performance settings
USE_GPU=false  # Set to true if CUDA/MPS available
MODEL_PRECISION=fp16  # fp32, fp16 for memory efficiency
BATCH_INFERENCE=true

# =============================================================================
# JWT Authentication Configuration
# =============================================================================

# Token settings
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
REMEMBER_ME_EXPIRE_DAYS=30

# Token security
JWT_ISSUER=intelliclaim-api
JWT_AUDIENCE=intelliclaim-app
JWT_LEEWAY=10  # seconds

# Password requirements
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_DIGITS=true
PASSWORD_REQUIRE_SPECIAL=true

# Account security
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION_MINUTES=15
PASSWORD_RESET_EXPIRE_MINUTES=60

# Multi-factor authentication
MFA_ENABLED=false
MFA_ISSUER=IntelliClaim
TOTP_DIGITS=6
TOTP_PERIOD=30

# =============================================================================
# Email Configuration
# =============================================================================

# SMTP Configuration
MAIL_ENABLED=true
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-specific-password  # Use app password for Gmail
MAIL_FROM=noreply@intelliclaim.com
MAIL_FROM_NAME=IntelliClaim Support

# Email security
MAIL_TLS=true
MAIL_SSL=false
MAIL_VALIDATE_CERTS=true

# Email templates
EMAIL_TEMPLATES_DIR=./templates/email
DEFAULT_EMAIL_LANGUAGE=en

# Email limits
MAX_EMAILS_PER_HOUR=100
EMAIL_RETRY_ATTEMPTS=3
EMAIL_RETRY_DELAY=300  # seconds

# Email types
SEND_WELCOME_EMAIL=true
SEND_PASSWORD_RESET_EMAIL=true
SEND_NOTIFICATION_EMAIL=true
SEND_PROCESSING_COMPLETE_EMAIL=true

# =============================================================================
# Monitoring and Logging Configuration
# =============================================================================

# Sentry Error Tracking
SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1  # 10% of transactions
SENTRY_PROFILES_SAMPLE_RATE=0.1

# Application Performance Monitoring
APM_ENABLED=false
APM_SERVICE_NAME=intelliclaim-api
APM_ENVIRONMENT=development

# Health checks
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_INTERVAL=30  # seconds
DB_HEALTH_CHECK_TIMEOUT=5
REDIS_HEALTH_CHECK_TIMEOUT=3

# Metrics
METRICS_ENABLED=true
PROMETHEUS_METRICS=true
METRICS_PREFIX=intelliclaim_api

# Request logging
LOG_REQUESTS=true
LOG_RESPONSES=false  # Be careful with sensitive data
LOG_REQUEST_BODY=false  # Only enable for debugging
LOG_SLOW_QUERIES=true
SLOW_QUERY_THRESHOLD=1.0  # seconds

# =============================================================================
# Cloud Storage Configuration (Optional)
# =============================================================================

# Storage provider: local, aws, azure, gcp
STORAGE_PROVIDER=local

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
AWS_BUCKET_NAME=intelliclaim-storage
AWS_REGION=us-east-1
AWS_ENDPOINT_URL=  # For S3-compatible services like MinIO

# Azure Blob Storage
AZURE_STORAGE_ACCOUNT_NAME=your-azure-storage-account
AZURE_STORAGE_ACCOUNT_KEY=your-azure-storage-key
AZURE_CONTAINER_NAME=intelliclaim-storage

# Google Cloud Storage
GOOGLE_CLOUD_PROJECT_ID=your-gcp-project-id
GOOGLE_CLOUD_BUCKET_NAME=intelliclaim-storage
GOOGLE_APPLICATION_CREDENTIALS=./path/to/service-account.json

# =============================================================================
# Development and Testing Configuration
# =============================================================================

# Development tools
RELOAD=true  # Auto-reload on code changes
DEBUG_TOOLBAR=true
PROFILING_ENABLED=false

# Testing
TESTING=false
TEST_DATA_DIR=./tests/data
MOCK_EXTERNAL_APIS=true
TEST_TIMEOUT=30

# Database seeding
SEED_DATABASE=false
SEED_USERS=10
SEED_CLAIMS=100

# Feature flags
FEATURE_AI_PROCESSING=true
FEATURE_BATCH_PROCESSING=true
FEATURE_REAL_TIME_NOTIFICATIONS=true
FEATURE_ADVANCED_ANALYTICS=false

# =============================================================================
# Integration Configuration
# =============================================================================

# Webhook configuration
WEBHOOKS_ENABLED=false
WEBHOOK_SECRET=your-webhook-secret-key
WEBHOOK_TIMEOUT=10

# Third-party integrations
INTEGRATION_TIMEOUT=30
RETRY_ATTEMPTS=3
RETRY_BACKOFF=2  # exponential backoff multiplier

# API Rate limiting for external services
EXTERNAL_API_RATE_LIMIT=60  # requests per minute
EXTERNAL_API_BURST_LIMIT=10

# =============================================================================
# Security Headers and Additional Settings
# =============================================================================

# Security headers
HSTS_MAX_AGE=31536000  # 1 year
CONTENT_SECURITY_POLICY=default-src 'self'
X_FRAME_OPTIONS=DENY
X_CONTENT_TYPE_OPTIONS=nosniff

# Session security
SESSION_COOKIE_SECURE=false  # Set to true in production with HTTPS
SESSION_COOKIE_HTTPONLY=true
SESSION_COOKIE_SAMESITE=lax

# API versioning
API_VERSION_HEADER=X-API-Version
DEFAULT_API_VERSION=1.0

# =============================================================================
# END OF CONFIGURATION
# =============================================================================
#
# Remember to:
# 1. Generate secure random values for SECRET_KEY and other secrets
# 2. Use strong passwords for database and Redis
# 3. Set up proper API keys for external services
# 4. Configure appropriate CORS origins for your frontend
# 5. Enable HTTPS in production
# 6. Set DEBUG=false in production
# 7. Use environment-specific values for staging/production
#
